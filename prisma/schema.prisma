generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  ADMIN
  MANAGEMENT
  STAFF
  GUEST
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?

  role      Role     @default(GUEST)

  userId    String?
  depart_id Int?
  address   String?
  number    String?

  department Department? @relation(fields: [depart_id], references: [depart_id])

  accounts Account[]
  sessions Session[]

  transactions Transaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Department {
  depart_id   Int    @id @default(autoincrement())
  depart_name String

  users User[]
}

model Category {
  category_id   String @id
  category_name String

  items  Item[]
  assets Asset[]
}

model Location {
  location_id   String @id
  location_name String

  items  Item[]
  assets Asset[]
}

model Item {
  item_id      String @id
  location_id  String
  category_id  String
  name         String
  status       Int
  image        String?
  qr_code_path String

  category Category @relation(fields: [category_id], references: [category_id])
  location Location @relation(fields: [location_id], references: [location_id])

  stockItems StockItem[]
  transactionDetails TransactionDetail[]
}

model Asset {
  asset_serial  String   @id
  category_id   String
  location_id   String
  name          String
  description   String
  qty           Int
  purchase_date  DateTime
  purchase_price Int?
  status        Int
  qr_code_path  String
  image         String?

  category Category @relation(fields: [category_id], references: [category_id])
  location Location @relation(fields: [location_id], references: [location_id])

  maintenances AssetMaintenance[]
  transactionDetails TransactionDetail[]
}

model StockItem {
  stock_id    String @id
  item_id     String
  current_qty Int
  min_qty     Int

  item Item @relation(fields: [item_id], references: [item_id])
}

model Transaction {
  id         String   @id @default(cuid())
  user_id    String
  action     Boolean
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  details TransactionDetail[]
}

model TransactionDetail {
  id             String @id @default(cuid())
  transaction_id String
  asset_serial   String?
  item_id        String?
  person_name    String
  qty            Int

  transaction Transaction @relation(fields: [transaction_id], references: [id])
  asset       Asset?      @relation(fields: [asset_serial], references: [asset_serial])
  item        Item?       @relation(fields: [item_id], references: [item_id])
}

model AssetMaintenance {
  maintenance_id String   @id
  asset_serial   String
  condition      Int
  note           String
  create_at      DateTime
  date_end       DateTime?
  status_maintain     Int
  attachment     String?

  asset Asset @relation(fields: [asset_serial], references: [asset_serial])
}
